{
    "name": "@pedalboard/scripts",
    "version": "0.2.6",
    "description": "A set of reusable scripts",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/scripts"
    },
    "files": [
        "dist"
    ],
    "bin": {
        "pedalboard-scripts": "./dist/src/pedalboard-scripts.js"
    },
    "scripts": {
        "test": "bazel test :vitest",
        "test:coverage": "bazel coverage :vitest --config=vitest_coverage --test_arg=--coverage.reportsDirectory=$(pwd)/coverage",
        "lint": "bazel test :lint",
        "build": "bazel run //packages/scripts:build_and_copy",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@types/glob": "catalog:",
        "@types/node": "catalog:",
        "@types/yargs": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "eslint": "catalog:",
        "vitest": "catalog:"
    },
    "dependencies": {
        "glob": "catalog:",
        "yargs": "catalog:"
    }
}
