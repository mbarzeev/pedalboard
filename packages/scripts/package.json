{
    "name": "@pedalboard/scripts",
    "version": "0.2.5",
    "description": "A set of reusable scripts",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/scripts"
    },
    "files": [
        "dist"
    ],
    "bin": {
        "pedalboard-scripts": "./dist/src/pedalboard-scripts.js"
    },
    "scripts": {
        "test": "bazel run //packages/scripts:jest -- --coverageDirectory=$(pwd)/coverage",
        "lint": "bazel run //packages/scripts:lint",
        "build": "bazel run //packages/scripts:build_and_copy",
        "test:watch": "jest --watch"
    },
    "devDependencies": {
        "@types/glob": "^8.0.0",
        "@types/node": "^18.11.0",
        "@types/yargs": "^17.0.0",
        "eslint": "10.1.0",
        "jest": "^27.4.3",
        "jest-cli": "27.4.3"
    },
    "dependencies": {
        "glob": "^8.0.3",
        "yargs": "^17.6.2"
    }
}
