{
    "name": "@pedalboard/git-hooks",
    "version": "1.1.1",
    "description": "A set of JS Git hooks",
    "main": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/git-hooks"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "exports": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js",
        "default": "./dist/esm/index.js"
    },
    "scripts": {
        "test": "bazel test :jest",
        "test:coverage": "bazel coverage :jest --config=html_coverage --test_arg=--coverageDirectory=$(pwd)/coverage",
        "lint": "bazel test ... --test_tag_filters=lint",
        "build": "bazel run //packages/git-hooks:build_and_copy",
        "test:watch": "jest --watch"
    },
    "devDependencies": {
        "@babel/core": "^7.16.5",
        "@babel/preset-env": "^7.16.11",
        "babel-jest": "^27.4.5",
        "eslint": "10.1.0",
        "jest": "^27.4.3",
        "jest-cli": "27.4.3",
        "typescript": "^4.6.4",
        "@types/node": "^18.11.0"
    }
}
