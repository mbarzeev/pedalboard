{
    "name": "@pedalboard/media-loader",
    "version": "0.1.9",
    "description": "A component that lets you take control over you media loading",
    "main": "./dist/esm/index.js",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/media-loader"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "exports": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js",
        "default": "./dist/esm/index.js"
    },
    "types": "./dist/types/index.d.ts",
    "scripts": {
        "test": "bazel test :vitest",
        "test:coverage": "bazel coverage :vitest --config=vitest_coverage --test_arg=--coverage.reportsDirectory=$(pwd)/coverage",
        "lint": "bazel test :lint",
        "build": "bazel run //packages/media-loader:build_and_copy",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "chromatic": "chromatic --only-changed --untraced package.json --untraced pnpm-lock.yaml --exit-zero-on-changes"
    },
    "devDependencies": {
        "@babel/core": "catalog:",
        "@babel/preset-env": "catalog:",
        "@babel/preset-react": "catalog:",
        "@storybook/addon-essentials": "catalog:",
        "@storybook/addon-interactions": "catalog:",
        "@storybook/addon-links": "catalog:",
        "@storybook/addon-onboarding": "catalog:",
        "@storybook/addon-styling-webpack": "catalog:",
        "@storybook/addons": "catalog:",
        "@storybook/blocks": "catalog:",
        "@storybook/client-api": "catalog:",
        "@storybook/react": "catalog:",
        "@storybook/react-webpack5": "catalog:",
        "@storybook/test": "catalog:",
        "@testing-library/jest-dom": "catalog:",
        "@testing-library/react": "catalog:",
        "@types/react": "catalog:",
        "@typescript-eslint/eslint-plugin": "catalog:",
        "@typescript-eslint/parser": "catalog:",
        "@typescript-eslint/utils": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "babel-loader": "catalog:",
        "chromatic": "catalog:",
        "css-loader": "catalog:",
        "esbuild": "catalog:",
        "esbuild-sass-plugin": "catalog:",
        "eslint": "catalog:",
        "eslint-plugin-react": "catalog:",
        "eslint-plugin-storybook": "catalog:",
        "jsdom": "catalog:",
        "react-responsive-carousel": "catalog:",
        "sass": "catalog:",
        "sass-loader": "catalog:",
        "storybook": "catalog:",
        "storybook-addon-sass-postcss": "catalog:",
        "style-loader": "catalog:",
        "typescript": "catalog:",
        "typescript-eslint": "catalog:",
        "vitest": "catalog:",
        "webpack": "catalog:",
        "webpack-dev-server": "catalog:"
    },
    "peerDependencies": {
        "prop-types": "^15.8.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    }
}
