{
    "name": "@pedalboard/hooks",
    "version": "0.3.5",
    "description": "A set of well-crafted React hooks",
    "main": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/hooks"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "exports": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js",
        "default": "./dist/esm/index.js"
    },
    "scripts": {
        "test": "bazel test :jest",
        "test:coverage": "bazel coverage :jest --config=html_coverage --cache_test_results=no --test_arg=--coverageDirectory=$(pwd)/coverage",
        "lint": "bazel run //packages/hooks:lint",
        "build": "bazel run //packages/hooks:build_and_copy",
        "test:watch": "jest --watch"
    },
    "peerDependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@babel/core": "^7.16.5",
        "@babel/preset-env": "^7.16.11",
        "@testing-library/react-hooks": "^7.0.2",
        "@types/react": "^18.3.1",
        "babel-jest": "^27.4.5",
        "esbuild": "^0.15.7",
        "esbuild-sass-plugin": "^2.4.5",
        "eslint": "10.1.0",
        "jest": "^27.4.3",
        "jest-cli": "^27.4.3",
        "typescript": "^5.3.3"
    }
}
