{
    "name": "@pedalboard/hooks",
    "version": "0.3.5",
    "description": "A set of well-crafted React hooks",
    "main": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/hooks"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "exports": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js",
        "default": "./dist/esm/index.js"
    },
    "scripts": {
        "test": "bazel test :vitest",
        "test:coverage": "bazel coverage :vitest --config=vitest_coverage --test_arg=--coverage.reportsDirectory=$(pwd)/coverage",
        "lint": "bazel test :lint",
        "build": "bazel run //packages/hooks:build_and_copy",
        "test:watch": "vitest"
    },
    "peerDependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@testing-library/react": "catalog:",
        "@types/react": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "esbuild": "catalog:",
        "esbuild-sass-plugin": "catalog:",
        "eslint": "catalog:",
        "jsdom": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
