{
    "name": "@pedalboard/stylelint-plugin-craftsmanlint",
    "version": "1.3.11",
    "description": "A set of StyleLint rules for your code craftsmanship",
    "main": "./dist/cjs/index.js",
    "types": "./dist/types/index.d.ts",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/stylelint-plugin-craftsmanlint"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "exports": {
        "require": "./dist/cjs/index.js",
        "default": "./dist/cjs/index.js"
    },
    "scripts": {
        "test": "bazel test :vitest",
        "test:coverage": "bazel coverage :vitest --config=vitest_coverage --test_arg=--coverage.reportsDirectory=$(pwd)/coverage",
        "lint": "bazel test :lint",
        "build": "bazel run //packages/stylelint-plugin-craftsmanlint:build_and_copy",
        "test:watch": "vitest",
        "ts-coverage": "typescript-coverage-report"
    },
    "typeCoverage": {
        "ignoreFiles": [
            "vitest.config.mts"
        ]
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^3.0.0",
        "csstype": "^3.1.1",
        "eslint": "10.1.0",
        "postcss": "^8.4.0",
        "ts-node": "^10.9.2",
        "typescript": "^4.6.4",
        "typescript-coverage-report": "^0.7.0",
        "vitest": "^3.0.0"
    },
    "dependencies": {
        "stylelint": "15.11.0"
    }
}
