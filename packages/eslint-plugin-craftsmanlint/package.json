{
    "name": "@pedalboard/eslint-plugin-craftsmanlint",
    "version": "1.2.19",
    "description": "A set of ESlint rules for your code craftsmanship",
    "main": "./dist/cjs/index.js",
    "types": "./dist/types/index.d.ts",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/eslint-plugin-craftsmanlint"
    },
    "files": [
        "dist"
    ],
    "exports": {
        "require": "./dist/cjs/index.js",
        "default": "./dist/cjs/index.js"
    },
    "scripts": {
        "test": "bazel test :jest",
        "test:coverage": "bazel coverage :jest --config=html_coverage --test_arg=--coverageDirectory=$(pwd)/coverage",
        "lint": "bazel run //packages/eslint-plugin-craftsmanlint:lint",
        "build": "bazel run //packages/eslint-plugin-craftsmanlint:build_and_copy",
        "test:watch": "jest --watch"
    },
    "devDependencies": {
        "@babel/core": "^7.16.5",
        "@babel/preset-env": "^7.16.11",
        "eslint": "10.1.0",
        "jest": "^27.4.3",
        "jest-cli": "27.4.3",
        "typescript": "^4.6.4"
    }
}
