{
    "name": "@pedalboard/eslint-plugin-craftsmanlint",
    "version": "1.2.19",
    "description": "A set of ESlint rules for your code craftsmanship",
    "main": "./dist/cjs/index.js",
    "types": "./dist/types/index.d.ts",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/eslint-plugin-craftsmanlint"
    },
    "files": [
        "dist"
    ],
    "exports": {
        "require": "./dist/cjs/index.js",
        "default": "./dist/cjs/index.js"
    },
    "scripts": {
        "test": "bazel test :vitest",
        "test:coverage": "bazel coverage :vitest --config=vitest_coverage --test_arg=--coverage.reportsDirectory=$(pwd)/coverage",
        "lint": "bazel test :lint",
        "build": "bazel run //packages/eslint-plugin-craftsmanlint:build_and_copy",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^3.0.0",
        "eslint": "10.1.0",
        "typescript": "^4.6.4",
        "vitest": "^3.0.0"
    }
}
