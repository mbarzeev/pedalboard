{
    "name": "@pedalboard/components",
    "version": "0.6.25",
    "description": "A set of well-crafted components",
    "main": "index.js",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/components"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "exports": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js",
        "default": "./dist/esm/index.js"
    },
    "scripts": {
        "test": "bazel test :vitest",
        "test:coverage": "bazel coverage :vitest --config=vitest_coverage --test_arg=--coverage.reportsDirectory=$(pwd)/coverage",
        "lint": "bazel test :lint :stylelint",
        "build": "bazel run //packages/components:build_and_copy",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "cy:open": "cypress open-ct",
        "cy:run": "cypress run-ct",
        "plop": "plop",
        "chromatic": "chromatic --only-changed --untraced package.json --untraced pnpm-lock.yaml --exit-zero-on-changes"
    },
    "devDependencies": {
        "@babel/core": "^7.16.5",
        "@babel/preset-env": "^7.16.11",
        "@babel/preset-react": "^7.16.7",
        "@babel/runtime": "^7.29.2",
        "@pedalboard/stylelint-plugin-craftsmanlint": "workspace:^",
        "@storybook/addon-essentials": "^7.6.12",
        "@storybook/addon-interactions": "^7.6.12",
        "@storybook/addon-links": "^7.6.12",
        "@storybook/addon-onboarding": "^1.0.11",
        "@storybook/addons": "^7.6.12",
        "@storybook/blocks": "^7.6.12",
        "@storybook/client-api": "^7.6.12",
        "@storybook/react": "^7.6.12",
        "@storybook/react-webpack5": "^7.6.12",
        "@storybook/test": "^7.6.12",
        "@testing-library/jest-dom": "^6.0.0",
        "@testing-library/react": "^16.0.0",
        "@types/prop-types": "^15.7.0",
        "@types/react": "^18.3.1",
        "@vitest/coverage-v8": "^3.0.0",
        "babel-loader": "^9.2.1",
        "chromatic": "10.6.1",
        "css-loader": "^6.0.0",
        "cypress": "^10.1.0",
        "eslint": "10.1.0",
        "eslint-plugin-react": "^7.28.0",
        "eslint-plugin-storybook": "^0.6.15",
        "jsdom": "^25.0.0",
        "plop": "^3.1.0",
        "postcss-scss": "^4.0.9",
        "sass": "^1.70.0",
        "sass-loader": "^14.1.0",
        "storybook": "^7.6.12",
        "storybook-addon-sass-postcss": "^0.3.2",
        "style-loader": "^3.0.0",
        "stylelint": "^14.16.0",
        "typescript": "^4.6.4",
        "vitest": "^3.0.0",
        "webpack": "^5.90.1",
        "webpack-dev-server": "4.15.1"
    },
    "peerDependencies": {
        "prop-types": "^15.8.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "dependencies": {
        "@pedalboard/hooks": "workspace:^"
    }
}
