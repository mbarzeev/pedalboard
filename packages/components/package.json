{
    "name": "@pedalboard/components",
    "version": "0.6.25",
    "description": "A set of well-crafted components",
    "main": "index.js",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git",
        "directory": "packages/components"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "exports": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js",
        "default": "./dist/esm/index.js"
    },
    "scripts": {
        "test": "bazel test :vitest",
        "test:coverage": "bazel coverage :vitest --config=vitest_coverage --test_arg=--coverage.reportsDirectory=$(pwd)/coverage",
        "lint": "bazel test :lint :stylelint",
        "build": "bazel run //packages/components:build_and_copy",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "cy:open": "cypress open-ct",
        "cy:run": "cypress run-ct",
        "plop": "plop",
        "chromatic": "chromatic --only-changed --untraced package.json --untraced pnpm-lock.yaml --exit-zero-on-changes"
    },
    "devDependencies": {
        "@babel/core": "catalog:",
        "@babel/preset-env": "catalog:",
        "@babel/preset-react": "catalog:",
        "@babel/runtime": "catalog:",
        "@pedalboard/stylelint-plugin-craftsmanlint": "workspace:^",
        "@storybook/addon-links": "catalog:",
        "@storybook/addon-styling-webpack": "catalog:",
        "@storybook/addon-webpack5-compiler-swc": "catalog:",
        "@storybook/react": "catalog:",
        "@storybook/react-webpack5": "catalog:",
        "@testing-library/jest-dom": "catalog:",
        "@testing-library/react": "catalog:",
        "@types/prop-types": "catalog:",
        "@types/react": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "babel-loader": "catalog:",
        "chromatic": "catalog:",
        "css-loader": "catalog:",
        "cypress": "catalog:",
        "eslint": "catalog:",
        "eslint-plugin-react": "catalog:",
        "eslint-plugin-storybook": "catalog:",
        "jsdom": "catalog:",
        "plop": "catalog:",
        "postcss-scss": "catalog:",
        "sass": "catalog:",
        "sass-loader": "catalog:",
        "storybook": "catalog:",
        "style-loader": "catalog:",
        "stylelint": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:",
        "webpack": "catalog:",
        "webpack-dev-server": "catalog:"
    },
    "peerDependencies": {
        "prop-types": "^15.8.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "dependencies": {
        "@pedalboard/hooks": "workspace:^"
    }
}
