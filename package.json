{
    "name": "pedalboard",
    "version": "1.0.0",
    "description": "A collection of packages to help you express you software better",
    "main": "index.js",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git"
    },
    "scripts": {
        "setup:git-hooks": "git config core.hooksPath .git-hooks",
        "postinstall": "pnpm run setup:git-hooks",
        "test": "bazel test //packages/... --test_tag_filters=vitest",
        "lint": "bazel test //packages/... --test_tag_filters=lint",
        "build": "pnpm -r run build",
        "version:changeset": "changeset version",
        "publish:changeset": "changeset publish",
        "coverage:all": "pnpm bazel coverage //packages/... --test_tag_filters=vitest --config=vitest_coverage",
        "coverage:report": "lcov-viewer lcov bazel-out/_coverage/_coverage_report.dat -o coverage",
        "coverage:combined": "pnpm coverage:all && pnpm coverage:report",
        "bazel": "bazel",
        "deps:lint": "syncpack lint"
    },
    "devDependencies": {
        "@babel/plugin-transform-runtime": "catalog:",
        "@babel/preset-typescript": "catalog:",
        "@babel/runtime": "catalog:",
        "@bazel/bazelisk": "catalog:",
        "@changesets/cli": "catalog:",
        "@eslint/eslintrc": "catalog:",
        "@eslint/js": "catalog:",
        "@lcov-viewer/cli": "catalog:",
        "@pedalboard/eslint-plugin-craftsmanlint": "workspace:^",
        "@pedalboard/git-hooks": "workspace:^",
        "@swc/core": "catalog:",
        "@typescript-eslint/eslint-plugin": "catalog:",
        "@typescript-eslint/parser": "catalog:",
        "chalk": "catalog:",
        "esbuild": "catalog:",
        "esbuild-sass-plugin": "catalog:",
        "globals": "catalog:",
        "syncpack": "catalog:",
        "ts-node": "catalog:",
        "vitest": "catalog:"
    },
    "dependencies": {
        "react": "catalog:",
        "react-dom": "catalog:"
    },
    "packageManager": "pnpm@9.15.4",
    "pnpm": {
        "overrides": {
            "parse-url": "^8.1.0"
        },
        "onlyBuiltDependencies": []
    }
}
