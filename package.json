{
    "name": "pedalboard",
    "version": "1.0.0",
    "description": "A collection of packages to help you express you software better",
    "main": "index.js",
    "author": "Matti Bar-Zeev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mbarzeev/pedalboard.git"
    },
    "scripts": {
        "setup:git-hooks": "git config core.hooksPath .git-hooks",
        "postinstall": "pnpm run setup:git-hooks",
        "test": "pnpm -r run test",
        "test:since": "pnpm --filter '...[origin/master]' run test",
        "lint": "pnpm -r run lint",
        "lint:since": "pnpm --filter '...[origin/master]' run lint",
        "build": "pnpm -r run build",
        "version:changeset": "changeset version",
        "publish:changeset": "changeset publish",
        "coverage": "pnpm run test --coverage",
        "coverage:all": "pnpm -r run test --coverage --silent",
        "coverage:collect": "mkdir -p .nyc_output && pedalboard-scripts collectFiles --pattern='packages/**/coverage-final.json' --target='.nyc_output'",
        "coverage:combined": "pnpm run coverage:all && pnpm run coverage:collect && nyc report --reporter lcov"
    },
    "devDependencies": {
        "@babel/plugin-transform-runtime": "^7.19.6",
        "@babel/preset-typescript": "^7.17.12",
        "@babel/runtime": "^7.29.2",
        "@changesets/cli": "^2.30.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@pedalboard/eslint-plugin-craftsmanlint": "^1.2.12",
        "@pedalboard/git-hooks": "^1.0.3",
        "@pedalboard/scripts": "^0.2.0",
        "@swc/core": "^1.3.24",
        "@swc/jest": "^0.2.24",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "esbuild": "^0.15.7",
        "esbuild-sass-plugin": "^2.4.5",
        "globals": "^17.4.0",
        "nyc": "^15.1.0",
        "ts-node": "^10.9.2"
    },
    "dependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "packageManager": "pnpm@9.15.4",
    "pnpm": {
        "overrides": {
            "parse-url": "^8.1.0",
            "@storybook/node-logger": "7.6.21"
        }
    }
}
